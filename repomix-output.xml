<file path="backup/firestore.rules">
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global function to enforce multi-tenant isolation
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /social_accounts/{accountId} {
      allow read, write: if isOwner(resource.data.user_id) || isOwner(request.resource.data.user_id);
    }

    match /posts/{postId} {
      allow read, write: if isOwner(resource.data.user_id) || isOwner(request.resource.data.user_id);
    }

    match /automations/{automationId} {
      allow read, write: if isOwner(resource.data.user_id) || isOwner(request.resource.data.user_id);
    }
  }
}
</file>

