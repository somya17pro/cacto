"use client";

import {
  BarChart3,
  Bot,
  Eye,
  Home,
  Link as LinkIcon,
  LogOut,
  Menu,
  Settings,
  Sparkles,
  X
} from "lucide-react";
import Link from "next/link";
import { usePathname, useRouter } from "next/navigation";
import { useEffect, useState } from "react";
import { bootstrapDemo, getBioPage, getUser, isAuthed, logout } from "@/lib/store";
import { Button } from "./ui";

const nav = [
  { href: "/app", label: "Dashboard", icon: Home },
  { href: "/app/bio", label: "Bio Page", icon: LinkIcon },
  { href: "/app/automations", label: "Automations", icon: Bot },
  { href: "/app/analytics", label: "Analytics", icon: BarChart3 },
  { href: "/app/settings", label: "Settings", icon: Settings }
];

export function AppShell({ children }: { children: React.ReactNode }) {
  const pathname = usePathname();
  const router = useRouter();
  const [open, setOpen] = useState(false);
  const [ready, setReady] = useState(false);

  useEffect(() => {
    bootstrapDemo();
    if (!isAuthed()) {
      router.replace("/login");
      return;
    }
    setReady(true);
  }, [router]);

  if (!ready) return <main className="grid min-h-screen place-items-center bg-paper text-sm font-semibold text-ink/60">Opening your studio...</main>;

  const user = getUser();
  const page = getBioPage();

  return (
    <div className="min-h-screen bg-paper">
      <aside
        className={`fixed inset-y-0 left-0 z-40 w-72 border-r border-ink/10 bg-white/85 px-4 py-5 backdrop-blur-xl transition lg:translate-x-0 ${
          open ? "translate-x-0" : "-translate-x-full"
        }`}
      >
        <div className="flex items-center justify-between px-2">
          <Link href="/app" className="flex items-center gap-3">
            <span className="grid h-10 w-10 place-items-center rounded-2xl bg-leaf text-lg font-black text-white">C</span>
            <div>
              <p className="text-lg font-black">Cacto</p>
              <p className="text-xs font-semibold text-ink/45">Creator growth studio</p>
            </div>
          </Link>
          <button className="lg:hidden" onClick={() => setOpen(false)} aria-label="Close navigation">
            <X className="h-5 w-5" />
          </button>
        </div>
        <nav className="mt-8 space-y-2">
          {nav.map((item) => {
            const Icon = item.icon;
            const active = pathname === item.href;
            return (
              <Link
                key={item.href}
                href={item.href}
                className={`flex min-h-12 items-center gap-3 rounded-2xl px-4 text-sm font-bold transition ${
                  active ? "bg-ink text-white shadow-soft" : "text-ink/62 hover:bg-ink/5 hover:text-ink"
                }`}
                onClick={() => setOpen(false)}
              >
                <Icon className="h-5 w-5" />
                {item.label}
              </Link>
            );
          })}
        </nav>
        <div className="mt-8 rounded-[26px] bg-moss p-5">
          <Sparkles className="h-5 w-5 text-leaf" />
          <p className="mt-3 text-sm font-black">MVP safe mode</p>
          <p className="mt-1 text-sm leading-5 text-ink/62">Instagram connection is simulated so the demo stays compliant and safe.</p>
        </div>
      </aside>
      <div className="lg:pl-72">
        <header className="sticky top-0 z-30 flex min-h-20 items-center justify-between border-b border-ink/10 bg-paper/80 px-4 backdrop-blur-xl sm:px-7">
          <div className="flex items-center gap-3">
            <button className="grid h-11 w-11 place-items-center rounded-2xl bg-white lg:hidden" onClick={() => setOpen(true)} aria-label="Open navigation">
              <Menu className="h-5 w-5" />
            </button>
            <div>
              <p className="text-sm font-bold text-ink/45">@{user.instagramHandle}</p>
              <h1 className="text-xl font-black text-ink sm:text-2xl">{user.brandName}</h1>
            </div>
          </div>
          <div className="flex items-center gap-2">
            <Link href={`/b/${page.slug}`}>
              <Button variant="secondary" className="hidden sm:inline-flex">
                <Eye className="h-4 w-4" />
                Preview
              </Button>
            </Link>
            <Button
              variant="ghost"
              className="px-3"
              onClick={() => {
                logout();
                router.replace("/");
              }}
            >
              <LogOut className="h-5 w-5" />
            </Button>
          </div>
        </header>
        <main className="px-4 py-6 sm:px-7 lg:py-8">{children}</main>
      </div>
    </div>
  );
}
