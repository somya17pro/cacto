import { NextResponse } from "next/server";
import { db } from "@/lib/server-data";

export async function PUT(request: Request, { params }: { params: Promise<{ id: string }> }) {
  const body = await request.json();
  const { id } = await params;
  const index = db.automations.findIndex((automation) => automation.id === id);
  if (index < 0) return NextResponse.json({ error: "Automation not found" }, { status: 404 });
  db.automations[index] = { ...db.automations[index], ...body, updatedAt: new Date().toISOString() };
  return NextResponse.json({ automation: db.automations[index] });
}
