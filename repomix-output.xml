  if (index < 0) return NextResponse.json({ error: "Bio page not found" }, { status: 404 });
  db.bioPages[index] = { ...db.bioPages[index], ...body, updatedAt: new Date().toISOString() };
  return NextResponse.json({ bioPage: db.bioPages[index] });
}

export async function GET(_request: Request, { params }: { params: Promise<{ id: string }> }) {
  const { id } = await params;
  const page = db.bioPages.find((item) => item.id === id || item.slug === id);
  if (!page) return NextResponse.json({ error: "Bio page not found" }, { status: 404 });
  return NextResponse.json({ bioPage: page });
}
