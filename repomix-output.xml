<file path="src/app/dashboard/page.tsx">
'use client'

import { useEffect, useState } from 'react'
import { useRouter } from 'next/navigation'
import { createClient } from '@/utils/supabase/client'
import { 
  Zap, 
  Settings, 
  CreditCard, 
  LogOut, 
  Plus, 
  CheckCircle, 
  Timer, 
  Activity, 
  Trash2, 
  MessageSquare,
  Sparkles,
  Link as LinkIcon,
  ChevronRight,
  TrendingUp,
  DollarSign,
  Users
} from 'lucide-react'

// Tab definitions
type Tab = 'automations' | 'accounts' | 'payments'

interface Automation {
  id: string
  triggerKeyword: string
  dmMessageCopy: string
  isActive: boolean
  createdAt: string
}

export default function Dashboard() {
  const [activeTab, setActiveTab] = useState<Tab>('automations')
  const [user, setUser] = useState<any>(null)
  const [isLoading, setIsLoading] = useState(true)
  const [isModalOpen, setIsModalOpen] = useState(false)
  
  // Form states
  const [keyword, setKeyword] = useState('')
  const [dmCopy, setDmCopy] = useState('')

  // App data states
  const [automations, setAutomations] = useState<Automation[]>([
    {
      id: '1',
      triggerKeyword: 'LINK',
      dmMessageCopy: 'Hey! Here is the link to my e-book: https://stan.store/my-ebook',
      isActive: true,
      createdAt: new Date().toISOString()
    },
    {
      id: '2',
      triggerKeyword: 'COURSE',
      dmMessageCopy: 'Thanks for asking! You can sign up for the cohort here: https://superprofile.bio/course',
      isActive: true,
      createdAt: new Date().toISOString()
    },
    {
      id: '3',
      triggerKeyword: 'FREE',
      dmMessageCopy: 'Awesome! Grab your free template here: https://beacons.ai/free-template',
      isActive: false,
      createdAt: new Date().toISOString()
    }
  ])

  const router = useRouter()
  const supabase = createClient()

  useEffect(() => {
    const checkAuth = async () => {
      // Check for dev bypass
      const isBypass = localStorage.getItem('cacto_bypass_auth') === 'true'
      if (isBypass) {
        setUser({ email: 'somyanayak281@gmail.com', id: 'mock-id' })
        setIsLoading(false)
        return
      }

      // Check real Supabase Auth
      const { data: { session } } = await supabase.auth.getSession()
      if (!session) {
        router.push('/login')
      } else {
        setUser(session.user)
        setIsLoading(false)
      }
    }

    checkAuth()
  }, [router, supabase])

  const handleSignOut = async () => {
    localStorage.removeItem('cacto_bypass_auth')
    await supabase.auth.signOut()
    router.push('/login')
  }

  const handleCreateAutomation = (e: React.FormEvent) => {
    e.preventDefault()
    if (!keyword || !dmCopy) return

    const newAuto: Automation = {
      id: Math.random().toString(),
      triggerKeyword: keyword.toUpperCase(),
      dmMessageCopy: dmCopy,
      isActive: true,
      createdAt: new Date().toISOString()
    }

    setAutomations([newAuto, ...automations])
    setKeyword('')
    setDmCopy('')
    setIsModalOpen(false)
  }

  const toggleAutomation = (id: string) => {
    setAutomations(
      automations.map(auto => 
        auto.id === id ? { ...auto, isActive: !auto.isActive } : auto
      )
    )
  }

  const deleteAutomation = (id: string) => {
    setAutomations(automations.filter(auto => auto.id !== id))
  }

  if (isLoading) {
    return (
      <div className="min-h-screen bg-[#0A0A0A] flex justify-center items-center">
        <div className="h-10 w-10 border-4 border-[#FF6B00]/20 border-t-[#FF6B00] rounded-full animate-spin" />
      </div>
    )
  }

  return (
    <div className="min-h-screen bg-[#0A0A0A] text-white flex">
      {/* Sidebar Navigation */}
      <aside className="w-64 bg-[#121212] border-r border-white/5 flex flex-col justify-between p-6">
        <div className="space-y-8">
          {/* Logo */}
          <div className="flex items-center gap-2">
            <Zap className="h-6 w-6 text-[#FF6B00] fill-[#FF6B00]" />
            <span className="text-xl font-bold tracking-tight">Cacto</span>
          </div>

          {/* Navigation Links */}
          <nav className="space-y-1">
            <button
              onClick={() => setActiveTab('automations')}
              className={`w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold transition ${
                activeTab === 'automations' 
                  ? 'bg-[#FF6B00] text-white' 
                  : 'text-zinc-400 hover:text-white hover:bg-white/5'
              }`}
            >
              <Sparkles className="h-4.5 w-4.5" />
              Automations
            </button>
            
            <button
              onClick={() => setActiveTab('accounts')}
              className={`w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold transition ${
                activeTab === 'accounts' 
                  ? 'bg-[#FF6B00] text-white' 
                  : 'text-zinc-400 hover:text-white hover:bg-white/5'
              }`}
            >
              <Settings className="h-4.5 w-4.5" />
              Accounts
            </button>

            <button
              onClick={() => setActiveTab('payments')}
              className={`w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold transition ${
                activeTab === 'payments' 
                  ? 'bg-[#FF6B00] text-white' 
                  : 'text-zinc-400 hover:text-white hover:bg-white/5'
              }`}
            >
              <CreditCard className="h-4.5 w-4.5" />
              Payments
            </button>
          </nav>
        </div>

        {/* User Info & Logout */}
        <div className="pt-6 border-t border-white/5 space-y-4">
          <div className="px-2 truncate">
            <p className="text-xs text-zinc-500 font-semibold mb-0.5">Signed in as</p>
            <p className="text-sm text-zinc-300 font-bold truncate">{user?.email}</p>
          </div>
          <button
            onClick={handleSignOut}
            className="w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold text-red-400 hover:bg-red-500/10 transition"
          >
            <LogOut className="h-4.5 w-4.5" />
            Sign Out
          </button>
        </div>
      </aside>

      {/* Main Content Area */}
      <main className="flex-1 bg-[#0A0A0A] p-10 overflow-y-auto relative">
        {/* Glow */}
        <div className="absolute top-0 right-0 w-96 h-96 bg-[#FF6B00]/5 blur-[128px] rounded-full pointer-events-none" />

        {/* AUTOMATIONS TAB */}
        {activeTab === 'automations' && (
          <div className="max-w-5xl mx-auto space-y-8 relative">
            {/* Header */}
            <div className="flex justify-between items-center">
              <div>
                <h1 className="text-3xl font-extrabold tracking-tight">Automations</h1>
                <p className="text-sm text-zinc-400 mt-1">Manage your auto-DM workflow rules</p>
              </div>
              <button
                onClick={() => setIsModalOpen(true)}
                className="px-5 py-3 rounded-xl bg-[#FF6B00] hover:bg-[#E05E00] text-white font-bold transition flex items-center gap-2 shadow-lg shadow-[#FF6B00]/10"
              >
                <Plus className="h-5 w-5" /> New Automation
              </button>
            </div>

            {/* Bento Grid Metrics */}
            <div className="grid grid-cols-1 md:grid-cols-4 gap-6">
              <div className="p-6 rounded-2xl bg-[#121212] border border-white/5 flex flex-col justify-between h-36">
                <span className="text-xs font-semibold text-zinc-500 uppercase tracking-wider">Active Rules</span>
                <span className="text-3xl font-black">{automations.filter(a => a.isActive).length}</span>
              </div>
              <div className="p-6 rounded-2xl bg-[#121212] border border-white/5 flex flex-col justify-between h-36">
                <span className="text-xs font-semibold text-zinc-500 uppercase tracking-wider">Total Sent</span>
                <span className="text-3xl font-black">2,481</span>
              </div>
              <div className="p-6 rounded-2xl bg-[#121212] border border-white/5 flex flex-col justify-between h-36">
                <span className="text-xs font-semibold text-zinc-500 uppercase tracking-wider">Avg Latency</span>
                <span className="text-3xl font-black text-green-400">1.8s</span>
              </div>
              <div className="p-6 rounded-2xl bg-[#121212] border border-white/5 flex flex-col justify-between h-36">
                <span className="text-xs font-semibold text-zinc-500 uppercase tracking-wider">Delivery Rate</span>
                <span className="text-3xl font-black text-[#FF6B00]">99.8%</span>
              </div>
            </div>

            {/* Automation Rules List */}
            <div className="space-y-4">
              <h2 className="text-xl font-bold tracking-tight mb-4">Active Triggers</h2>
              {automations.length === 0 ? (
                <div className="p-12 text-center rounded-2xl bg-[#121212] border border-white/5">
                  <p className="text-zinc-500 text-sm">No automations created yet.</p>
                </div>
              ) : (
                automations.map(auto => (
                  <div key={auto.id} className="p-6 rounded-2xl bg-[#121212] border border-white/5 flex justify-between items-center hover:border-white/10 transition duration-200">
                    <div className="flex items-center gap-4">
                      <div className="p-3.5 rounded-xl bg-[#FF6B00]/10 text-[#FF6B00] border border-[#FF6B00]/20">
                        <MessageSquare className="h-5 w-5" />
                      </div>
                      <div>
                        <div className="flex items-center gap-2">
                          <span className="text-xs font-semibold text-zinc-400">If comment is:</span>
                          <span className="px-2 py-0.5 rounded bg-white/5 text-xs font-extrabold tracking-wider border border-white/10 text-white">
                            {auto.triggerKeyword}
                          </span>
                        </div>
                        <p className="text-zinc-300 text-sm font-medium mt-2 max-w-xl truncate">
                          Reply: "{auto.dmMessageCopy}"
                        </p>
                      </div>
                    </div>

                    <div className="flex items-center gap-6">
                      {/* Active Toggle Switch */}
                      <button
                        onClick={() => toggleAutomation(auto.id)}
                        className={`w-12 h-6.5 rounded-full transition duration-300 relative ${
                          auto.isActive ? 'bg-[#FF6B00]' : 'bg-white/10'
                        }`}
                      >
                        <div className={`w-5 h-5 bg-white rounded-full absolute top-0.5 shadow transition-all duration-300 ${
                          auto.isActive ? 'left-6.5' : 'left-0.5'
                        }`} />
