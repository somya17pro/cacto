<file path="backup/app/onboarding/page.tsx">
"use client";

import { ArrowRight, Bot, Check, Instagram, Link as LinkIcon, Sparkles } from "lucide-react";
import { useRouter } from "next/navigation";
import { useEffect, useMemo, useState } from "react";
import { BioPreview } from "@/components/bio-preview";
import { Button, Input, Textarea } from "@/components/ui";
import { getBioPage, getUser, isAuthed, saveBioPage, saveUser } from "@/lib/store";

const goals = ["Grow an email list", "Sell digital products", "Book more calls"];

export default function OnboardingPage() {
  const router = useRouter();
  const [step, setStep] = useState(0);
  const [user, setUser] = useState(getUser());
  const [page, setPage] = useState(getBioPage());
  const steps = useMemo(() => ["Welcome", "Goal", "Brand", "Bio", "Automation", "Finish"], []);

  useEffect(() => {
    if (!isAuthed()) router.replace("/login");
  }, [router]);

  function next() {
    saveUser(user);
    saveBioPage(page);
    if (step === steps.length - 1) router.push("/app");
    else setStep((current) => current + 1);
  }

  return (
    <main className="min-h-screen px-5 py-8">
      <div className="mx-auto max-w-6xl">
        <div className="flex items-center justify-between">
          <div className="flex items-center gap-3">
            <span className="grid h-10 w-10 place-items-center rounded-2xl bg-ink text-lg font-black text-white">C</span>
            <span className="font-black">Cacto setup</span>
          </div>
          <p className="text-sm font-bold text-ink/45">{step + 1} of {steps.length}</p>
        </div>
        <div className="mt-6 h-2 overflow-hidden rounded-full bg-ink/10">
          <div className="h-full rounded-full bg-leaf transition-all" style={{ width: `${((step + 1) / steps.length) * 100}%` }} />
        </div>
        <section className="mt-8 grid gap-8 rounded-[36px] border border-ink/10 bg-white/82 p-6 shadow-soft backdrop-blur lg:grid-cols-[1fr_420px] lg:p-10">
          <div className="flex min-h-[540px] flex-col justify-center">
            {step === 0 && (
              <div>
                <Sparkles className="h-10 w-10 text-leaf" />
                <h1 className="mt-5 text-5xl font-black leading-tight">Let’s shape your creator growth studio.</h1>
                <p className="mt-5 max-w-xl text-lg leading-8 text-ink/62">We’ll set up your brand, bio page, and first Instagram comment-to-DM flow.</p>
              </div>
            )}
            {step === 1 && (
              <div>
                <h1 className="text-4xl font-black">What do you want Cacto to help with first?</h1>
                <div className="mt-7 grid gap-3">
                  {goals.map((goal) => (
                    <button
                      key={goal}
                      onClick={() => setUser({ ...user, goal })}
                      className={`flex min-h-16 items-center justify-between rounded-2xl border px-5 text-left font-black transition ${
                        user.goal === goal ? "border-leaf bg-moss text-leaf" : "border-ink/10 bg-white"
                      }`}
                    >
                      {goal}
                      {user.goal === goal && <Check className="h-5 w-5" />}
                    </button>
                  ))}
                </div>
              </div>
            )}
            {step === 2 && (
              <div className="space-y-5">
                <h1 className="text-4xl font-black">Add your brand basics.</h1>
                <label className="block">
                  <span className="mb-2 block text-sm font-bold text-ink/55">Brand name</span>
                  <Input value={user.brandName} onChange={(event) => {
                    setUser({ ...user, brandName: event.target.value });
                    setPage({ ...page, brandName: event.target.value });
                  }} />
                </label>
                <label className="block">
                  <span className="mb-2 flex items-center gap-2 text-sm font-bold text-ink/55"><Instagram className="h-4 w-4" /> Instagram handle</span>
                  <Input value={user.instagramHandle} onChange={(event) => setUser({ ...user, instagramHandle: event.target.value.replace("@", "") })} />
                </label>
              </div>
            )}
            {step === 3 && (
              <div className="space-y-5">
                <h1 className="text-4xl font-black">Draft your public bio page.</h1>
                <Input value={page.headline} onChange={(event) => setPage({ ...page, headline: event.target.value })} />
                <Textarea value={page.description} onChange={(event) => setPage({ ...page, description: event.target.value })} />
                <Input value={page.cta} onChange={(event) => setPage({ ...page, cta: event.target.value })} />
              </div>
            )}
            {step === 4 && (
              <div>
                <Bot className="h-10 w-10 text-leaf" />
                <h1 className="mt-5 text-4xl font-black">Your first automation is ready to customize.</h1>
                <p className="mt-4 max-w-xl text-lg leading-8 text-ink/62">The demo starts with a safe Instagram connection and a CONTENT keyword flow you can edit later.</p>
              </div>
            )}
            {step === 5 && (
              <div>
                <Check className="h-12 w-12 rounded-full bg-moss p-2 text-leaf" />
                <h1 className="mt-5 text-5xl font-black leading-tight">You’re ready to publish.</h1>
                <p className="mt-5 max-w-xl text-lg leading-8 text-ink/62">Open the dashboard to manage links, automations, and analytics from one place.</p>
              </div>
            )}
            <Button className="mt-10 w-fit" onClick={next}>
              {step === steps.length - 1 ? "Go to dashboard" : "Continue"}
              <ArrowRight className="h-4 w-4" />
            </Button>
          </div>
          <div className="rounded-[34px] bg-ink p-4">
            <BioPreview page={page} compact />
            <div className="mt-4 rounded-3xl bg-white/10 p-4 text-white">
              <div className="flex items-center gap-3">
                <LinkIcon className="h-5 w-5 text-sun" />
                <p className="font-black">cacto.so/b/{page.slug}</p>
              </div>
            </div>
          </div>
        </section>
      </div>
    </main>
  );
}
