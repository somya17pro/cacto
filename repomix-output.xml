"use client";

import { analyticsSeries, demoAutomations, demoBioPage, demoUser } from "./demo-data";
import type { AnalyticsPoint, Automation, BioPage, User } from "./types";

const keys = {
  user: "cacto:user",
  bio: "cacto:bio",
  automations: "cacto:automations",
  analytics: "cacto:analytics",
  authed: "cacto:authed"
};

function read<T>(key: string, fallback: T): T {
  if (typeof window === "undefined") return fallback;
  const raw = window.localStorage.getItem(key);
  if (!raw) return fallback;
  try {
    return JSON.parse(raw) as T;
  } catch {
    return fallback;
  }
}

function write<T>(key: string, value: T) {
  if (typeof window === "undefined") return;
  window.localStorage.setItem(key, JSON.stringify(value));
}

export function bootstrapDemo() {
  if (typeof window === "undefined") return;
  if (!window.localStorage.getItem(keys.user)) write(keys.user, demoUser);
  if (!window.localStorage.getItem(keys.bio)) write(keys.bio, demoBioPage);
  if (!window.localStorage.getItem(keys.automations)) write(keys.automations, demoAutomations);
  if (!window.localStorage.getItem(keys.analytics)) write(keys.analytics, analyticsSeries);
}

export function login(email = demoUser.email, name = demoUser.name) {
  bootstrapDemo();
  const user = { ...getUser(), email, name };
  write(keys.user, user);
  window.localStorage.setItem(keys.authed, "true");
  return user;
}

export function logout() {
  if (typeof window === "undefined") return;
  window.localStorage.removeItem(keys.authed);
}

export function isAuthed() {
  if (typeof window === "undefined") return false;
  return window.localStorage.getItem(keys.authed) === "true";
}

export function getUser(): User {
  return read(keys.user, demoUser);
}

export function saveUser(user: User) {
  write(keys.user, user);
}

export function getBioPage(): BioPage {
  return read(keys.bio, demoBioPage);
}

export function saveBioPage(page: BioPage) {
  write(keys.bio, page);
}

export function getAutomations(): Automation[] {
  return read(keys.automations, demoAutomations);
}

export function saveAutomations(automations: Automation[]) {
  write(keys.automations, automations);
}

export function getAnalytics(): AnalyticsPoint[] {
  return read(keys.analytics, analyticsSeries);
}
</file>

