<file path="backup/app/api/links/[id]/route.ts">
import { NextResponse } from "next/server";
import { db } from "@/lib/server-data";

export async function PUT(request: Request, { params }: { params: Promise<{ id: string }> }) {
  const body = await request.json();
  const { id } = await params;
  for (const page of db.bioPages) {
    const index = page.links.findIndex((link) => link.id === id);
    if (index >= 0) {
      page.links[index] = { ...page.links[index], ...body };
      return NextResponse.json({ link: page.links[index] });
    }
  }
  return NextResponse.json({ error: "Link not found" }, { status: 404 });
}

export async function DELETE(_request: Request, { params }: { params: Promise<{ id: string }> }) {
  const { id } = await params;
  for (const page of db.bioPages) {
    const before = page.links.length;
    page.links = page.links.filter((link) => link.id !== id);
    if (page.links.length !== before) return NextResponse.json({ ok: true });
  }
  return NextResponse.json({ error: "Link not found" }, { status: 404 });
}
