import * as functions from "firebase-functions";
import * as admin from "firebase-admin";

admin.initializeApp();
const db = admin.firestore();

// 1. Zernio Webhook Listener
export const zernioWebhookListener = functions.https.onRequest(async (req, res) => {
  try {
    // Basic structural validation for the webhook payload
    const payload = req.body;
    if (!payload || payload.type !== "comment.received") {
      res.status(400).send("Invalid webhook type");
      return;
    }

    const accountId = payload.accountId;
    const postId = payload.postId;
    const commentText = payload.commentText?.toLowerCase() || "";
    const commenterUsername = payload.commenterUsername;

    // 2. Query Firestore automations collection for the specific post
    const automationsRef = db.collection("automations");
    const snapshot = await automationsRef
      .where("post_id", "==", postId)
      .where("is_active", "==", true)
      .get();

    if (snapshot.empty) {
      // No active automations for this post
      res.status(200).send("No active automations found.");
      return;
    }

    // 3. Find the matching trigger keyword
    let matchedAutomation = null;
    for (const doc of snapshot.docs) {
      const data = doc.data();
      const trigger = data.trigger_keyword.toLowerCase();
      if (commentText.includes(trigger)) {
        matchedAutomation = { id: doc.id, ...data };
        break; // Stop at the first matched keyword
      }
    }

    if (!matchedAutomation) {
      res.status(200).send("No matching trigger word found in comment.");
      return;
    }

    // 4. Follow-Gate Check (Mock logic - in production, check Zernio contact property)
    if (matchedAutomation.follow_gate_enabled) {
      // Verify if the user follows the account (requires querying Zernio API or Meta API)
      const isFollowing = true; // Hardcoded for MVP phase
      if (!isFollowing) {
        res.status(200).send("Follow gate failed. User not following.");
        return;
      }
    }

    // 5. Dispatch DM via Zernio REST API (Mock API Call)
    console.log(`[Zernio Outbound] Sending DM to ${commenterUsername}: ${matchedAutomation.dm_message_copy}`);
    
    // TODO: Implement actual HTTP POST to Zernio API:
    // await fetch("https://api.zernio.com/v1/messages/send", { ... })

    // 6. Update Analytics Metrics
    await db.collection("automations").doc(matchedAutomation.id).update({
      "metrics.comments_processed": admin.firestore.FieldValue.increment(1),
      "metrics.dms_sent": admin.firestore.FieldValue.increment(1),
    });

    res.status(200).send("DM Dispatched Successfully!");
  } catch (error) {
    console.error("Webhook processing error:", error);
    res.status(500).send("Internal Server Error");
  }
});
