        <p className="mt-2 leading-6 text-ink/58">Start with a local MVP account, then finish onboarding in a few guided steps.</p>
        <form
          className="mt-7 space-y-4"
          onSubmit={(event) => {
            event.preventDefault();
            login(email, name);
