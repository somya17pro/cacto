<file path="backup/lib/controllers/auth_controller.dart">
import 'package:flutter/material.dart';
import 'package:firebase_auth/firebase_auth.dart';
import 'package:shared_preferences/shared_preferences.dart';
import '../services/firebase_service.dart';

class AuthController extends ChangeNotifier {
  User? get currentUser => AppFirebase.auth.currentUser;
  bool get isAuthenticated => currentUser != null;
  bool isLoading = false;

  AuthController() {
    _handleIncomingMagicLink();
  }

  Future<void> _handleIncomingMagicLink() async {
    String url = Uri.base.toString();
    if (AppFirebase.auth.isSignInWithEmailLink(url)) {
      isLoading = true;
      notifyListeners();
      try {
        final prefs = await SharedPreferences.getInstance();
        String? email = prefs.getString('emailForSignIn');
        
        // Fix for cross-domain local storage: extract email from URL if missing
        if (email == null) {
          final uri = Uri.parse(url);
          email = uri.queryParameters['email'];
        }
        
        if (email != null) {
          await AppFirebase.auth.signInWithEmailLink(email: email, emailLink: url);
          await prefs.remove('emailForSignIn');
        } else {
          debugPrint("Email not found in SharedPreferences or URL.");
        }
      } catch (e) {
        debugPrint("Error signing in with link: $e");
      } finally {
        isLoading = false;
        notifyListeners();
      }
    }
  }

  Future<bool> sendMagicLink(String email) async {
    isLoading = true;
    notifyListeners();
    try {
      final prefs = await SharedPreferences.getInstance();
      await prefs.setString('emailForSignIn', email);

      var actionCodeSettings = ActionCodeSettings(
        url: 'https://cacto-8323f.firebaseapp.com/finishSignUp?cartId=1234&email=$email',
        handleCodeInApp: true,
        iOSBundleId: 'com.cacto.app',
        androidPackageName: 'com.cacto.app',
        androidInstallApp: true,
        androidMinimumVersion: '12',
      );
      await AppFirebase.auth.sendSignInLinkToEmail(
        email: email,
        actionCodeSettings: actionCodeSettings,
      );
      return true;
    } catch (e) {
      debugPrint("Error sending magic link: $e");
      return false;
    } finally {
      isLoading = false;
      notifyListeners();
    }
  }

  Future<void> signOut() async {
    await AppFirebase.auth.signOut();
    notifyListeners();
  }
}
</file>

<file path="backup/lib/controllers/dashboard_controller.dart">
import 'package:flutter/material.dart';
import 'package:cloud_firestore/cloud_firestore.dart';
import '../services/firebase_service.dart';
import '../models/automation_model.dart';
import '../models/social_account_model.dart';
import 'package:firebase_auth/firebase_auth.dart';

class DashboardController extends ChangeNotifier {
  final FirebaseFirestore _db = AppFirebase.firestore;
  User? get _user => AppFirebase.auth.currentUser;
  String get _uid => _user?.uid ?? "mock_developer_user";

  List<SocialAccountModel> connectedAccounts = [];
  List<AutomationModel> automations = [];
  bool isLoading = false;

  DashboardController() {
    fetchAccounts();
    fetchAutomations();
  }

  Future<void> fetchAccounts() async {
    isLoading = true;
    notifyListeners();

    try {
      var snapshot = await _db
          .collection('social_accounts')
          .where('user_id', isEqualTo: _uid)
          .get();
      
      connectedAccounts = snapshot.docs
          .map((doc) => SocialAccountModel.fromJson(doc.data()))
          .toList();
    } catch (e) {
      debugPrint("Error fetching accounts: $e");
    } finally {
      isLoading = false;
      notifyListeners();
    }
  }

  Future<void> fetchAutomations() async {
    isLoading = true;
    notifyListeners();

    try {
      var snapshot = await _db
          .collection('automations')
          .where('user_id', isEqualTo: _uid)
          .get();
      
      automations = snapshot.docs
          .map((doc) => AutomationModel.fromJson(doc.data()..['automation_id'] = doc.id))
          .toList();
    } catch (e) {
      debugPrint("Error fetching automations: $e");
    } finally {
      isLoading = false;
      notifyListeners();
    }
  }

  Future<void> createAutomation(String keyword, String dmCopy) async {
    try {
      final docRef = _db.collection('automations').doc();
      final newAutomation = AutomationModel(
        automationId: docRef.id,
        userId: _uid,
        postId: "global_all_posts", // MVP Simplification: apply to all posts
        triggerKeyword: keyword,
        dmMessageCopy: dmCopy,
        isActive: true,
        followGateEnabled: false,
        createdAt: DateTime.now(),
      );

      await docRef.set(newAutomation.toJson());
      automations.add(newAutomation);
      notifyListeners();
    } catch (e) {
      debugPrint("Error creating automation: $e");
    }
  }
}
