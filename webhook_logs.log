agree to our \",\"termsLink\":\"Terms of Service\",\"and\":\"and\",\"privacyPolicy\":\"Privacy Policy\"},\"fields\":{\"fullName\":{\"label\":\"Full name\",\"placeholder\":\"John Doe\"},\"email\":{\"label\":\"Email address\",\"placeholder\":\"your@email.com\"},\"password\":{\"label\":\"Password\",\"placeholder\":\"At least 6 characters\",\"show\":\"Show password\",\"hide\":\"Hide password\"}},\"testimonial\":{\"quote\":\"I use Zernio as my backbone for automating social media\",\"author\":\"Jeffry Viveros · CTO, Ucademy\",\"trustedBy\":\"Trusted by teams at\"}},\"signinPage\":{\"meta\":{\"title\":\"Zernio\"},\"hero\":{\"title\":\"Welcome back\",\"subtitle\":\"Sign in to access your social media scheduling dashboard\"},\"codeSnippet\":{\"title\":\"# Schedule across 15 platforms\",\"curl\":\"curl -X POST https://zernio.com/api/v1/posts \\\\\\n  -H \\\"Authorization: Bearer YOUR_API_KEY\\\" \\\\\\n  -d '{\\\"content\\\": \\\"Hello, world! 🌍\\\"}'\"},\"info\":{\"verified\":\"Your email is verified. You can sign in now.\",\"error\":{\"google\":\"Failed to sign in with Google\",\"github\":\"Failed to sign in with GitHub\",\"invalid\":\"Invalid email or password\",\"session\":\"Authentication succeeded but session not found. Please try refreshing the page.\",\"generic\":\"Failed to sign in\"},\"verificationRequired\":\"Please verify your email to continue. Check your inbox for the verification link.\"},\"actions\":{\"google\":\"Continue with Google\",\"github\":\"Continue with GitHub\",\"submit\":\"Sign in\",\"forgotPassword\":\"Forgot your password?\",\"noAccount\":\"Don't have an account? \",\"createAccount\":\"Create a free account\",\"backToHome\":\"Back to home\",\"toggleOpen\":\"Sign in with email\",\"toggleClose\":\"Hide email sign in\"},\"fields\":{\"email\":{\"label\":\"Email address\",\"placeholder\":\"your@email.com\"},\"password\":{\"label\":\"Password\",\"placeholder\":\"••••••••\",\"show\":\"Show password\",\"hide\":\"Hide password\"}},\"tos\":{\"disclaimer\":\"By continuing, you agree to our \",\"terms\":\"Terms of Service\",\"and\":\"and\",\"privacy\":\"Privacy Policy\"}},\"verifyEmail\":{\"subtitle\":\"We sent a 6-digit code to\",\"editEmail\":\"Wrong email? Edit\",\"verifying\":\"Verifying...\",\"resendIdle\":\"Resend code\",\"resendCountdown\":\"Resend code ({seconds}s)\",\"resendSent\":\"New code sent.\",\"expired\":\"This code has expired. Please request a new one.\",\"genericError\":\"Something went wrong. Please try again.\"},\"openPage\":{\"meta\":{\"title\":\"Zernio Open Analytics - Daily posting activity\",\"description\":\"Our production numbers, live and unfiltered. Posts published, platforms that broke, errors we fixed. Updated daily.\"},\"hero\":{\"title\":\"No vanity metrics. Just the real thing.\",\"subtitle\":\"A live look at the last 90 days of posts flowing through Zernio. Wins, fails, and everything between. We don't hide the messy parts.\"},\"cards\":{\"whatsThis\":{\"title\":\"What is this?\",\"description\":\"Aggregated, anonymized production data. Every data point is a real post that hit our API. No synthetic benchmarks, no demos.\"},\"whyShareFails\":{\"title\":\"Why show failures?\",\"description\":\"APIs break. Tokens expire. Platforms return 500s at 2am. Showing it builds more trust than any landing page ever could.\"},\"useWisely\":{\"title\":\"What's not here\",\"description\":\"No user data, no post content, no account info. Just volumes and outcomes. Fully anonymized, updated with every deploy.\"}}},\"platformPages\":{\"facebook\":{\"hero\":{\"title\":\"Ship Your Facebook Integration\",\"highlight\":\"In Minutes, Not Months\",\"subtitle\":\"Stop wrestling with Meta's Business API. Zernio handles OAuth, rate limits, page management, and API changes - so you can focus on building your product.\"},\"stats\":{\"integration\":\"Facebook Pages integration\",\"media\":\"Photos, videos \u0026 links\",\"compliance\":\"Meta Business API compliant\"},\"notice\":{\"title\":\"Facebook Business Page Required\",\"description\":\"Facebook API integration requires a Business page. Personal profiles cannot use automated posting APIs due to Meta's restrictions.\",\"conversionTip\":\"You must be an admin of the page to connect it.\"},\"ctas\":{\"primary\":\"Start Free Trial\",\"secondary\":\"View API Docs\",\"docsLink\":\"View Complete API Documentation\"},\"comparison\":{\"title\":\"Why Zernio vs Meta Business API?\",\"subtitle\":\"Skip the Meta Business API headaches\",\"officialTitle\":\"Meta Business API\",\"lateTitle\":\"Zernio API\",\"painPoints\":{\"oauth\":\"Complex OAuth with Facebook Business verification\",\"rateLimit\":\"Rate limit management with backoff logic\",\"media\":\"Media must meet strict Meta requirements\",\"maintenance\":\"Constant updates when Graph API changes\",\"platforms\":\"Build separate integrations per platform\"},\"benefits\":{\"auth\":\"Simple API key - start in 30 seconds\",\"rateLimit\":\"Automatic retries \u0026 queue management\",\"media\":\"Upload directly - we optimize for Meta\",\"maintenance\":\"Zero maintenance forever\",\"platforms\":\"One API for 15 platforms\"},\"timeSaving\":\"Save 4-6 weeks of development.\",\"timeSavingText\":\"Ship Facebook API integration today, not next month.\"},\"features\":{\"title\":\"Why 10,000+ Developers Choose Zernio\",\"cards\":{\"scheduling\":{\"title\":\"Ship Faster\",\"description\":\"Go from zero to posting in under 30 seconds. No Facebook app review, no Business Manager headaches - just get your API key and start building.\"},\"metaApi\":{\"title\":\"Official API, Zero Hassle\",\"description\":\"We use Meta's official Business API under the hood. You get full compliance and reliability without the integration pain.\"},\"management\":{\"title\":\"We Handle the Hard Parts\",\"description\":\"Rate limits, token refresh, media processing, error handling - all managed for you. Focus on your product, not infrastructure.\"}}},\"howItWorks\":{\"title\":\"Three Steps to Facebook Automation\",\"steps\":{\"connect\":{\"title\":\"Connect Your Page\",\"description\":\"Link your Facebook Business page through our dashboard. One-click OAuth - we handle all the Meta permissions.\"},\"schedule\":{\"title\":\"Build Your Integration\",\"description\":\"Use our simple REST API to schedule posts with text, images, videos, or links. Same pattern works for all 15 platforms.\"},\"publish\":{\"title\":\"We Handle the Rest\",\"description\":\"Zernio publishes at your scheduled time, retries on failures, and notifies you via webhooks. You never touch Meta's API directly.\"}}},\"codeExample\":{\"title\":\"Get Started in 30 Seconds\",\"snippetTitle\":\"Schedule a Facebook Post\",\"language\":\"JavaScript\",\"snippet\":\"const response = await fetch('https://zernio.com/api/v1/posts', {\\n  method: 'POST',\\n  headers: {\\n    'Authorization': 'Bearer YOUR_API_KEY',\\n    'Content-Type': 'application/json'\\n  },\\n  body: JSON.stringify({\\n    platforms: [{\\n      platform: 'facebook',\\n      accountId: 'your-facebook-page-id'\\n    }],\\n    content: 'Exciting news! Check out our latest update 🚀',\\n    mediaItems: [{\\n      type: 'image',\\n      url: 'https://your-image-url.jpg'\\n    }],\\n    scheduledFor: '2024-01-15T14:00:00Z'\\n  })\\n});\\n\\nconst result = await response.json();\\nconsole.log('Scheduled successfully:', result.id);\"},\"contentTypes\":{\"title\":\"Every Facebook Format Supported\",\"items\":{\"text\":{\"label\":\"Text Posts\",\"description\":\"Plain text updates\"},\"photos\":{\"label\":\"Photos\",\"description\":\"JPEG, PNG, WebP\"},\"videos\":{\"label\":\"Videos\",\"description\":\"MP4, MOV\"},\"links\":{\"label\":\"Links\",\"description\":\"With preview cards\"}}},\"benefits\":{\"title\":\"Facebook Marketing Benefits\",\"list\":{\"reach\":{\"title\":\"Reach Billions\",\"description\":\"Tap into Facebook's massive user base with automated posting. Schedule content to reach your audience at optimal times.\"},\"multiPage\":{\"title\":\"Multi-Page Management\",\"description\":\"Manage multiple Facebook Pages from a single API. Perfect for agencies and businesses with multiple brands.\"},\"businessApi\":{\"title\":\"Business-Grade API\",\"description\":\"Built on Meta's Business API with enterprise-level reliability. Rate limiting, error handling, and retry mechanisms included.\"}},\"featuresTitle\":\"Facebook Features Supported\",\"featuresList\":{\"text\":\"Text, photo, and video posts\",\"links\":\"Link sharing with preview\",\"management\":\"Facebook Page management\",\"scheduling\":\"Scheduled publishing\",\"accounts\":\"Multiple account support\",\"status\":\"Real-time status tracking\",\"compliance\":\"Meta Business API compliant\"}},\"errorReference\":{\"title\":\"Facebook API Error Reference\",\"description\":\"Comprehensive guide to Facebook API error codes. Find solutions and troubleshoot common integration issues.\",\"cta\":\"View Error Reference\"},\"faq\":{\"title\":\"Frequently Asked Questions\",\"items\":{\"businessPage\":{\"question\":\"Do I need a Facebook Business page?\",\"answer\":\"Yes, Facebook API integration requires a Facebook Business page. You cannot post to personal profiles via API due to Meta's restrictions. You must be an admin of the page to connect it.\"},\"whyNotDirect\":{\"question\":\"Why use Zernio instead of Meta's API directly?\",\"answer\":\"Meta's Business API requires Facebook app verification, complex OAuth flows, media hosting, rate limit management, and ongoing maintenance. Zernio abstracts all of that - you get a simple API key and start posting in minutes.\"},\"groups\":{\"question\":\"Can I post to Facebook Groups via API?\",\"answer\":\"Facebook restricts automated posting to Groups via third-party APIs. Zernio supports posting to Facebook Pages, which is the standard for business and brand automation.\"},\"crossPost\":{\"question\":\"Can I cross-post to Instagram from the same API call?\",\"answer\":\"Yes. Include both 'facebook' and 'instagram' in your platforms array, or 13 other platforms that we support. Zernio optimizes media and content for each platform automatically.\"},\"cost\":{\"question\":\"How much does the Facebook API cost?\",\"answer\":\"Facebook's Graph API is free to use, but the integration costs weeks of engineering for Meta Business verification, OAuth, and ongoing version maintenance. Zernio is free up to 2 accounts and pay only for what you use beyond that.\"}}},\"learnMore\":{\"title\":\"Learn More\",\"items\":[{\"title\":\"Facebook API Guide\",\"description\":\"Complete developer guide\",\"link\":\"/blog/facebook-api\"},{\"title\":\"Facebook Messenger API\",\"description\":\"Build a Facebook Messenger chatbot\",\"link\":\"/blog/facebook-messenger-api\"},{\"title\":\"Posting API\",\"description\":\"Post, schedule and analyze content\",\"link\":\"/social-media-api\"}]},\"otherPlatforms\":{\"title\":\"One API, 15 Platforms\",\"subtitle\":\"Same integration pattern for all platforms\"},\"finalCta\":{\"title\":\"Ready to Ship Your Facebook Integration?\",\"subtitle\":\"Join 10,000+ developers who chose Zernio over building with Meta's API directly. Same reliability, 10x less code.\",\"primary\":\"Start Free Trial\",\"secondary\":\"Read Documentation\",\"footnote\":\"No credit card required • 99.97% uptime SLA\"}},\"instagram\":{\"hero\":{\"title\":\"Ship Your Instagram Integration\",\"highlight\":\"In Minutes, Not Months\",\"subtitle\":\"Stop wrestling with Instagram Graph API. Zernio's Instagram API handles OAuth, rate limits, media hosting, and API changes - so you can focus on building your product.\"},\"stats\":{\"media\":\"Photos, videos \u0026 carousels\",\"stories\":\"Stories \u0026 Reels support\",\"businessOnly\":\"Business accounts only\"},\"notice\":{\"title\":\"Instagram Business Account Required\",\"description\":\"Instagram integration only works with Business accounts. Personal and Creator accounts cannot use automated posting APIs due to Instagram's restrictions.\",\"conversionTip\":\