:\"0\",\"style\":{\"display\":\"none\",\"visibility\":\"hidden\"}}]}],[\"$\",\"$L12\",null,{\"children\":[[\"$\",\"$L13\",null,{}],[\"$\",\"$L14\",null,{\"messages\":{\"common\":{\"app\":{\"name\":\"Zernio\",\"tagline\":\"One API to post everywhere. 15 platforms, zero headaches.\",\"uptime\":\"99.97% uptime\",\"postsDelivered\":\"2.3M+ posts delivered\",\"cta\":\"Get Started\"},\"platformComparison\":\"Platform Comparison\"},\"header\":{\"sr\":{\"open\":\"Open main menu\",\"close\":\"Close menu\"},\"links\":{\"docs\":\"Docs\",\"pricing\":\"Pricing\"},\"ctas\":{\"dashboard\":\"Dashboard\",\"signup\":\"Start for Free\",\"signupMobile\":\"Start Free\"},\"features\":{\"title\":\"Features\",\"links\":{\"socialMediaApi\":{\"label\":\"Social Media API\",\"description\":\"REST API for all platforms\"},\"postScheduler\":{\"label\":\"Post Scheduler\",\"description\":\"Schedule posts in advance\"},\"contentCalendar\":{\"label\":\"Content Calendar\",\"description\":\"Visual planning interface\"},\"queuePosts\":{\"label\":\"Queue Posts\",\"description\":\"Automated posting slots\"},\"firstComment\":{\"label\":\"First Comment\",\"description\":\"Auto-add first comments\"},\"bulkScheduling\":{\"label\":\"Bulk Scheduling\",\"description\":\"CSV bulk upload\"},\"teamCollaboration\":{\"label\":\"Team Collaboration\",\"description\":\"Unlimited team members\"},\"analytics\":{\"label\":\"Analytics\",\"description\":\"Track engagement metrics\"},\"toolsApi\":{\"label\":\"Tools API\",\"description\":\"Downloaders, captions \u0026 more\"}}}},\"footer\":{\"brand\":{\"tagline\":\"One API to post everywhere. 15 platforms, zero headaches.\"},\"stats\":{\"uptime\":\"99.97% uptime\",\"postsDelivered\":\"2.3M+ posts delivered\"},\"sections\":{\"product\":{\"title\":\"PRODUCT\",\"links\":{\"docs\":\"Documentation\",\"dashboard\":\"Dashboard\",\"pricing\":\"Pricing\",\"features\":\"Features\",\"tools\":\"Tools\",\"templates\":\"n8n Templates\",\"roadmap\":\"Roadmap\"}},\"integrations\":{\"title\":