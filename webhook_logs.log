tion\":\"Visual calendar with drag-and-drop.\"},\"queuePosts\":{\"title\":\"Queue Posts\",\"description\":\"Automated posting slots at optimal times.\"},\"firstComment\":{\"title\":\"First Comment\",\"description\":\"Auto-add first comments on publish.\"},\"bulkScheduling\":{\"title\":\"Bulk Scheduling\",\"description\":\"Upload hundreds of posts via CSV.\"},\"teamCollaboration\":{\"title\":\"Team Collaboration\",\"description\":\"Unlimited team members on all plans.\"},\"analytics\":{\"title\":\"Analytics\",\"description\":\"Engagement metrics across all platforms.\"},\"commentToDm\":{\"title\":\"Comment to DM\",\"description\":\"Auto-DM users who comment keywords.\"},\"commentsApi\":{\"title\":\"Comments API\",\"description\":\"Read, reply, and moderate comments via API.\"},\"dmsApi\":{\"title\":\"DMs API\",\"description\":\"Send and receive DMs across 7 platforms.\"},\"toolsApi\":{\"title\":\"Tools API\",\"description\":\"Video downloaders, transcripts, and captions.\"},\"ads\":{\"title\":\"Ads Manager\",\"description\":\"Boost posts and run paid ads across 7 platforms.\"}}},\"home\":{\"hero\":{\"badge\":\"Social Media API for Developers \u0026 Agencies\",\"title\":\"#1 Social Media API\",\"description\":\"One API to schedule posts and get analytics for Twitter, Instagram, TikTok, LinkedIn, Facebook, YouTube, Threads, Reddit, Pinterest, and Bluesky.\",\"highlight\":\"Built for developers. Loved by agencies. Trusted by 6,325 users.\",\"primaryCta\":\"Start for free →\",\"secondaryCta\":\"Sign up with Google\",\"replacesLabel\":\"Replaces:\",\"logos\":{\"buffer\":{\"title\":\"Buffer\",\"alt\":\"Buffer logo\"},\"hootsuite\":{\"title\":\"Hootsuite\",\"alt\":\"Hootsuite logo\"},\"metricool\":{\"title\":\"Metricool\",\"alt\":\"Metricool logo\"},\"publer\":{\"title\":\"Publer\",\"alt\":\"Publer logo\"},\"ayrshare\":{\"title\":\"Ayrshare\",\"alt\":\"Ayrshare logo\"},\"blotato\":{\"title\":\"Blotato\",\"alt\":\"Blotato logo\"}},\"platforms\":{\"x\":\"X/Twitter\",\"instagram\":\"Instagram\",\"tiktok\":\"TikTok\",\"linkedin\":\"LinkedIn\",\"facebook\":\"Facebook\",\"youtube\":\"YouTube\",\"threads\":\"Threads\",\"reddit\":\"Reddit\",\"pinterest\":\"Pinterest\",\"bluesky\":\"Bluesky\",\"googlebusiness\":\"Google Business\",\"telegram\":\"Telegram\",\"snapchat\":\"Snapchat\"}},\"banner\":{\"ctas\":{\"details\":\"View docs\"}},\"review\":{\"title\":\"Loved by 6,325 users\",\"ratingLabel\":\"4.7/5\",\"videoLabel\":\"🎥 Real customer review\",\"quoteText\":\"Zernio is the first one that actually reduced my workload instead of adding more steps.\",\"attribution\":\"Jeremy Bengtson, Oct 2025\"},\"n8n\":{\"title\":\"Official n8n community node\",\"features\":{\"prebuilt\":{\"label\":\"Pre-built workflows\",\"description\":\"Install @n8n/n8n-nodes-zernio from npm\"},\"visual\":{\"label\":\"Visual workflow builder\",\"description\":\"Drag, drop, and connect Zernio to 1000+ other services\"},\"nocode\":{\"label\":\"No-code automation\",\"description\":\"Trigger posts from webhooks, schedules, or other apps\"},\"templates\":{\"label\":\"Community templates\",\"description\":\"Browse ready-made workflows in n8n's template library\"}},\"ctas\":{\"primary\":\"View n8n integration →\"}},\"threeWays\":{\"title\":\"Three ways to post\",\"items\":{\"rest\":{\"title\":\"1. REST API for developers\",\"description\":\"Integrate directly into your app. One API call posts to all 15 platforms instantly.\",\"border\":\"border-yellow-400\",\"hoverBorder\":\"hover:border-yellow-300\",\"hoverBg\":\"hover:bg-yellow-400/5\",\"hoverShadow\":\"hover:shadow-yellow-400/10\",\"hoverText\":\"group-hover:text-yellow-100\"},\"dashboard\":{\"title\":\"2. Dashboard for creators\",\"description\":\"Upload posts directly through our web dashboard. No coding required. Drag, drop, post.\",\"border\":\"border-yellow-400\",\"hoverBorder\":\"hover:border-purple-400\",\"hoverBg\":\"hover:bg-purple-400/5\",\"hoverShadow\":\"hover:shadow-purple-400/10\",\"hoverText\":\"group-hover:text-purple-100\"},\"n8n\":{\"title\":\"3. n8n workflows\",\"description\":\"Use our official n8n community node. Build complex automation workflows visually.\",\"border\":\"border-yellow-400\",\"hoverBorder\":\"hover:border-green-400\",\"hoverBg\":\"hover:bg-green-400/5\",\"hoverShadow\":\"hover:shadow-green-400/10\",\"hoverText\":\"group-hover:text-green-100\"}}},\"dashboard\":{\"title\":\"No-code dashboard included\",\"features\":{\"creators\":{\"label\":\"For creators\",\"description\":\"Upload posts directly via web dashboard\"},\"agencies\":{\"label\":\"For agencies\",\"description\":\"Manage multiple client accounts in one place\"},\"everyone\":{\"label\":\"For everyone\",\"description\":\"Preview posts before publishing\"},\"media\":{\"label\":\"Media support\",\"description\":\"Images, videos, carousels - all handled automatically\"}},\"cta\":\"Try dashboard →\"},\"why\":{\"title\":\"Why developers choose Zernio\",\"uptime\":{\"title\":\"99.97% uptime SLA\",\"description\":\"Enterprise-grade infrastructure. We handle rate limits, retries, and platform changes automatically.\"},\"oneApi\":{\"title\":\"One API, all platforms\",\"description\":\"Stop managing Twitter API v2, Instagram Graph API, TikTok API, LinkedIn API, and 5 others. We handle it all.\"},\"scale\":{\"title\":\"Built for scale\",\"description\":\"From your first connected account to thousands. Our infrastructure scales with your business.\"},\"whiteLabel\":{\"title\":\"White-label ready\",\"description\":\"Perfect for agencies. Your clients never know you're using a third-party service.\"}},\"api\":{\"title\":\"Simple API\",\"note\":\"✨ That's it. Your post goes live on all 15 platforms instantly.\"},\"agency\":{\"title\":\"Perfect for agencies\",\"multiClient\":{\"title\":\"Multi-client management\",\"description\":\"Manage dozens of client accounts from one dashboard. Switch between clients instantly.\"},\"collaboration\":{\"title\":\"Team collaboration\",\"description\":\"Add team members to specific clients. Control permissions and access levels.\"},\"whiteLabel\":{\"title\":\"White-label ready\",\"description\":\"API responses don't mention Zernio. Your clients never know you're using us.\"}},\"platforms\":{\"title\":\"All platforms supported\",\"subtitle\":\"Connect your accounts once, post everywhere\",\"cards\":{\"x\":{\"name\":\"X.com\"},\"instagram\":{\"name\":\"Instagram\"},\"tiktok\":{\"name\":\"TikTok\"},\"linkedin\":{\"name\":\"LinkedIn\"},\"facebook\":{\"name\":\"Facebook\"},\"youtube\":{\"name\":\"YouTube\"},\"threads\":{\"name\":\"Threads\"},\"reddit\":{\"name\":\"Reddit\"},\"pinterest\":{\"name\":\"Pinterest\"},\"bluesky\":{\"name\":\"Bluesky\"}}},\"value\":{\"title\":\"Stop overpaying for social media tools\",\"buffer\":{\"title\":\"Buffer charges $5/channel/month\",\"description\":\"Zernio is free up to 2 accounts and pay only for what you use beyond that, across all 15 platforms with a single API call.\",\"iconAlt\":\"Buffer logo\",\"iconSrc\":\"/images/logos/buffer.webp\"},\"hootsuite\":{\"title\":\"Hootsuite costs $99/month minimum\",\"description\":\"Zernio is usage-based: free up to 2 accounts, then pay only for what you use beyond that. No monthly minimum, no per-user fees.\",\"iconAlt\":\"Hootsuite logo\",\"iconSrc\":\"/images/logos/hootsuite.webp\"},\"metricool\":{\"title\":\"Metricool: $20/month for 5 brands\",\"description\":\"Zernio is free up to 2 accounts, then pay only for what you use beyond that. Plus full API access on every plan.\",\"iconAlt\":\"Metricool logo\",\"iconSrc\":\"/images/logos/metricool.webp\"},\"late\":{\"title\":\"Zernio: free up to 2 accounts, then usage-based\",\"description\":\"Pay only for what you use. Full API access, dashboard, n8n integration, agency tools, all included on every plan.\",\"iconAlt\":\"Zernio logo\",\"iconSrc\":\"/images/icon (7).webp\"}},\"pricing\":{\"title\":\"Simple pricing for every team\",\"cta\":\"View all plans →\"},\"cta\":{\"title\":\"Start building today\",\"subtitle\":\"Join 6,000+ developers, creators, and agencies using Zernio\",\"primary\":\"Try it free →\",\"secondary\":\"Read docs ↗\"},\"faq\":{\"platforms\":{\"question\":\"What platforms does Zernio support?\",\"answer\":\"Zernio supports 15 social media platforms: Twitter/X, Instagram, TikTok, LinkedIn, Facebook, YouTube, Threads, Reddit, Pinterest, Bluesky, Google Business, Telegram, Snapchat, WhatsApp, and Discord. You can post to all platforms with a single API call. We also support paid advertising on Meta Ads, Google Ads, TikTok Ads, LinkedIn Ads, Pinterest Ads, and X Ads.\"},\"api\":{\"question\":\"How does Zernio's API work?\",\"answer\":\"Zernio provides a simple REST API that allows you to schedule posts across all supported platforms with a single API call. Just send your content and media to our /posts endpoint, and we handle the rest including platform-specific formatting and posting.\"},\"difference\":{\"question\":\"What's the difference between Zernio and other social media tools?\",\"answer\":\"Zernio is built specifically for developers and agencies. Unlike tools like Buffer ($5/channel/month annual or $6/channel monthly) or Hootsuite ($99/month minimum), Zernio is free up to 2 accounts and pay only for what you use beyond that, across all 15 platforms, with full API access, no-code dashboard, and n8n integration on every plan.\"},\"freePlan\":{\"question\":\"Do you offer a free plan?\",\"answer\":\"Yes. Zernio is free up to 2 social accounts. You can post unlimited times across all platforms with full API access. Beyond 2 accounts, you pay only for what you use ($6 per account, scaling down to $1 at higher volume, and the $1 rate continues at any scale, fully self-service).\"},\"uptime\":{\"question\":\"What is Zernio's uptime guarantee?\",\"answer\":\"Zernio maintains a 99.97% uptime SLA with enterprise-grade infrastructure. We automatically handle rate limits, retries, and platform changes so your posts are delivered reliably.\"},\"n8n\":{\"question\":\"Can I use Zernio with n8n?\",\"answer\":\"Yes! Zernio has an official n8n community node available on npm (@n8n/n8n-nodes-zernio). You can build complex automation workflows visually and connect Zernio to 1000+ other services.\"}}},\"pricingPage\":{\"promoBanner\":{\"headline\":\"Pay yearly, get 2 months free.\",\"cta\":\"\"},\"hero\":{\"title\":\"Start free. Scale when you're ready.\",\"subtitle\":\"No hidden fees, no per-platform charges. One API for every social network.\",\"badge\":\"PRICING\"},\"socialProof\":{\"trustedBy\":\"Trusted by teams at\",\"customersCount\":\"500+ teams ship with Zernio\",\"usedBy\":\"Used by\"},\"toggle\":{\"monthly\":\"Monthly\",\"annual\":\"Annual\",\"payAnnually\":\"Pay annually,\",\"monthsFree\":\"2 months free\"},\"trust\":{\"uptime\":\"99.7% uptime\",\"postsDelivered\":\"1M+ posts delivered\",\"moneyBack\":\"30-day money-back\"},\"faq\":{\"title\":\"Frequently asked questions\",\"included\":{\"question\":\"What's included with every account?\",\"answer\":\"Every connected social account includes scheduling, analytics, inbox (comments + DMs), full API access, and unlimited posts. There are no separate add-ons or feature tiers.\"},\"howPricing\":{\"question\":\"How does the pricing work?\",\"answer\":\"You pay per connected social account per month. The first 2 accounts are free. After that, pricing is graduated: $6/account for 1-10, $3/account for 11-100, $1/account for 101+ (no cap). Each tier only applies to accounts within that range.\"},\"freeTier\":{\"question\":\"Is there a free tier?\",\"answer\":\"Yes. Your first 2 connected social accounts are completely free, no credit card required. You get full access to all features including scheduling, analytics, inbox, and the API.\"},\"twitter\":{\"question\":\"Why are X/Twitter API costs separate?\",\"answer\":\"X (Twitter) charges per API call on their end. We pass through their exact rates with zero markup so you only pay for what you use. Analytics and inbox sync for X accounts are opt-in, so you control the costs.\"},\"paymentMethods\":{\"question\":\"What payment methods do you accept?\",\"answer\":\"We accept all major credit cards (Visa, MasterCard, American Express) and process payments securely through Stripe.\"},\"setupFee\":{\"question\":\"Is there a setup fee?\",\"answer\":\"No. No setup fees, no hidden costs, no contracts. You pay per account per month, billed at the end of each billing period.\"},\"cancel\":{\"question\":\"Can I disconnect accounts anytime?\",\"answer\":\"Yes. Disconnect any social account at any time and you stop being charged for it. There are no cancellation fees or penalties.\"},\"refunds\":{\"question\":\"Do you offer refunds?\",\"answer\":\"Zernio is usage-based, so you only pay for the social accounts you actually connect during each billing period. There's no prepaid time to refund, and you can stop incurring charges at any time by disconnecting accounts. If you spot a billing error or were charged because of an outage on our side, email support and we'll credit your account.\"},\"scheduleVideos\":{\"question\":\"Can I schedule videos?\",\"answer\":\"Yes! You can schedule videos to YouTube, TikTok, Instagram (Reels), Facebook, LinkedIn, and Pinterest. We support all major video formats.\"},\"needDeveloper\":{\"question\":\"Do I need to be a developer to use Zernio?\",\"answer\":\"Zernio is built for developers and teams with technical resources. If you can make API calls, you can use Zernio. We also integrate with no-code tools like n8n, Make, and Zapier.\"},\"reliability\":{\"question\":\"How reliable is the service?\",\"answer\":\"We maintain 99.7%+ uptime and have delivered over 2 million posts. Our infrastructure runs on Vercel with global edge distribution, and we monitor every post delivery in real-time.\"}},\"stillHaveQuestions\":\"Still have questions?\",\"chatWithUs\":\"Chat with us\",\"finalCta\":{\"title\":\"Ready to get started?\",\"subtitle\":\"Start with our free plan and upgrade as you gr